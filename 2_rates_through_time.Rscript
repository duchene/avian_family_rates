# Raw dn branch lengths (not rates) are far less related to edge duration in time.
plot(log(colMeans(crxdn$raw.rates.matrix, na.rm = T)*sptr_unr$edge.length), log(sptr_unr$edge.length), pch = 20, ylab = "Log branch length in time", xlab = "Log dn branch length", col = as.numeric(sptr_unr$edge[,2] %in% 1:Ntip(sptr_unr))+1)
# Raw dn tips alone actually have no relationship with edge length in time:
plot(log(colMeans(crxdn$raw.rates.matrix, na.rm = T)[tips]*sptr_unr$edge.length[tips]), log(sptr_unr$edge.length[tips]), pch = 20, ylab = "Log branch length in time", xlab = "Log tips dn branch length")
# While internal branch lengths far more so:
